# Telegram API credentials (user account)
API_ID=xxxxxx
API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target supergroup (forum)
TARGET_GROUP=-100xxxxxxxxxx

# Telethon session name (optional)
SESSION_NAME=user_session

# Telegram log bot (optional)
TELEGRAM_LOG_ENABLED=false
TELEGRAM_LOG_BOT_TOKEN=123456789:AAxxxxxxx
TELEGRAM_LOG_CHAT_ID=-100xxxxxxxxxx

# INFO | WARNING | ERROR | CRITICAL (INFO = “enable all logs”
TELEGRAM_LOG_LEVEL=INFO

# MTProto Proxy Settings
PROXY_URL=https://raw.githubusercontent.com/DineshValor/telegram-bot/refs/heads/master/MTProto_proxies.txt
PROXY_REFRESH_HOURS=12
PROXY_MAX_FAILS=3

# Tips:
# • use keyboard arrows to move up/down/left/right
# • to save file => CTRL + X → Y → Enter
